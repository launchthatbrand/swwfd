registry=https://registry.npmjs.org/
ignore-engines=true

# Private package scopes (GitHub Packages)
@acme:registry=https://npm.pkg.github.com
@launchthatapp:registry=https://npm.pkg.github.com
@launchthatbrand:registry=https://npm.pkg.github.com

# GitHub Packages auth for CI/Vercel installs.
# Set GITHUB_PACKAGES_TOKEN in the deployment environment.
# Do not commit real tokens to this repository.
//npm.pkg.github.com/:_authToken=${GITHUB_PACKAGES_TOKEN}
always-auth=true

# Local auth should come from ~/.npmrc (or CI secret env vars).
