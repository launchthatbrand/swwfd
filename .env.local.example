# Copy to `.env.local` for local development.
#
# Convex dev deployment:
# - https://proficient-ram-973.convex.cloud
# - https://proficient-ram-973.convex.site

# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=dev:proficient-ram-973 # team: launchthatbrand, project: swwfd

NEXT_PUBLIC_CONVEX_URL=https://proficient-ram-973.convex.cloud

NEXT_PUBLIC_CONVEX_SITE_URL=https://proficient-ram-973.convex.site

# DEV-ONLY: enable /api/dev/auth-bypass for browser automation.
# This route will sign in (or sign up) via Convex Auth Password provider and
# redirect with auth cookies set.
SWWFD_DEV_AUTH_BYPASS_ENABLED=false
SWWFD_DEV_AUTH_BYPASS_EMAIL=desmond.tatilian@qcausa.com
# SWWFD_DEV_AUTH_BYPASS_PASSWORD=change-me-in-local

# Monday embedded board manager
# Create a Monday API token and provide the board id to power /monday
# MONDAY_SIGNING_SECRET=your-monday-app-signing-secret
# MONDAY_API_KEY=your-monday-api-token
# MONDAY_BOARD_ID=1234567890
# MONDAY_EMAIL_TEMPLATES_BOARD_ID=18401299370

