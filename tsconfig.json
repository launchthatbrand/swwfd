{
  "extends": "@acme/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2022", "dom", "dom.iterable"],
    "jsx": "preserve",
    "paths": {
      "~/*": ["./src/*"],
      "@convex-config/*": ["./convex/*"],
      "@launchthatapp/plugin-core-tenant": [
        "../../packages/plugins/core-tenant/src/index.ts"
      ],
      "@launchthatapp/plugin-core-tenant/*": [
        "../../packages/plugins/core-tenant/src/*"
      ]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": [".", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
